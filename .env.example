# ===================================================================
# StratosCode environment variables
# Copy this file to .env.local and fill values. Never commit .env.local
# ===================================================================

# AWS — server-side only, NEVER prefix with NEXT_PUBLIC_
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3
S3_BUCKET_NAME=stratoscode-artifacts
S3_OUTPUT_PREFIX=outputs/

# Step Functions
SFN_STATE_MACHINE_ARN=

# SageMaker
SAGEMAKER_ENDPOINT_NAME=stratoscode-transform

# Bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20251001

# Aurora PostgreSQL (use RDS Proxy or Neon for serverless connection pooling)
DATABASE_URL=

# DynamoDB
DYNAMODB_TABLE_NAME=stratoscode-transformations

# NextAuth / Cognito
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://stratoscode.vercel.app
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=https://cognito-idp.<region>.amazonaws.com/<user-pool-id>

# Dev mode — when 'true', AWS SDK calls fall back to deterministic mock data
# Useful for local UI dev without real AWS resources. Default: false in production.
STRATOSCODE_DEV_MOCK=false
